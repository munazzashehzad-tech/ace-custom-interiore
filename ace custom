// Micro-animations on scroll
function reveal() {
    var reveals = document.querySelectorAll(".reveal");

    for (var i = 0; i < reveals.length; i++) {
        var windowHeight = window.innerHeight;
        var elementTop = reveals[i].getBoundingClientRect().top;
        var elementVisible = 150;

        if (elementTop < windowHeight - elementVisible) {
            reveals[i].classList.add("active");
        }
    }
}

// Trigger once on load
window.addEventListener("scroll", reveal);
reveal();

// Smooth scroll logic for nav anchors is handled by CSS scroll-behavior: smooth, 
// but we can add navbar styling on scroll here:
const navbar = document.querySelector('.navbar');

window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
        navbar.style.boxShadow = '0 4px 20px rgba(0,0,0,0.1)';
        navbar.style.padding = '0.5rem 0';
    } else {
        navbar.style.boxShadow = '0 1px 15px rgba(0, 0, 0, 0.05)';
        navbar.style.padding = '1rem 0';
    }
});

/* Design System & Variables */
:root {
    /* Primary Colors: Grey & Orange Theme */
    --color-orange: #F26A2E;
    --color-orange-hover: #D9561C;
    --color-grey-dark: #1A1A1A;
    --color-grey-mid: #333333;
    --color-grey-light: #F4F4F5;
    --color-grey-border: #E5E7EB;
    --color-white: #FFFFFF;

    /* Typography */
    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Inter', sans-serif;

    /* Layout */
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --radius: 12px;
}

/* Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: var(--font-body);
    color: var(--color-grey-mid);
    background-color: var(--color-white);
    line-height: 1.6;
    overflow-x: hidden;
}

h1,
h2,
h3,
h4,
.logo-text {
    font-family: var(--font-heading);
    color: var(--color-grey-dark);
}

a {
    text-decoration: none;
    color: inherit;
}

ul {
    list-style: none;
}

/* Utilities */
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
}

.bg-light {
    background-color: var(--color-grey-light);
}

.section {
    padding: 6rem 0;
}

.section-header {
    text-align: center;
    margin-bottom: 4rem;
}

.section-header h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    position: relative;
    display: inline-block;
}

.section-header h2::after {
    content: '';
    position: absolute;
    width: 60%;
    height: 4px;
    background: var(--color-orange);
    bottom: -8px;
    left: 20%;
    border-radius: 2px;
}

.section-header p {
    font-size: 1.125rem;
    color: #666;
}

.grid {
    display: grid;
    gap: 2rem;
}

/* Buttons */
.btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    font-weight: 600;
    border-radius: var(--radius);
    transition: var(--transition);
    cursor: pointer;
    font-family: var(--font-heading);
}

.btn-primary {
    background-color: var(--color-orange);
    color: var(--color-white);
    border: 2px solid var(--color-orange);
}

.btn-primary:hover {
    background-color: var(--color-orange-hover);
    border-color: var(--color-orange-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(242, 106, 46, 0.3);
}

.btn-secondary {
    background-color: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-white);
}

.btn-secondary:hover {
    background-color: var(--color-white);
    color: var(--color-grey-dark);
    transform: translateY(-2px);
}

/* Navigation */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    z-index: 1000;
    box-shadow: 0 1px 15px rgba(0, 0, 0, 0.05);
    padding: 1rem 0;
    transition: var(--transition);
}

.nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
}

.logo-text {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-grey-dark);
    letter-spacing: -1px;
}

.logo-subtext {
    color: var(--color-orange);
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
}

.nav-links a:not(.btn) {
    font-weight: 500;
    font-size: 0.95rem;
    transition: var(--transition);
}

.nav-links a:not(.btn):hover {
    color: var(--color-orange);
}

/* Hero Section */
.hero {
    height: 100vh;
    min-height: 600px;
    background: linear-gradient(rgba(26, 26, 26, 0.8), rgba(26, 26, 26, 0.7)),
        url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover no-repeat;
    display: flex;
    align-items: center;
    position: relative;
}

.hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
}

.hero-title {
    font-size: 4.5rem;
    color: var(--color-white);
    line-height: 1.1;
    margin-bottom: 1.5rem;
}

.hero-title span {
    color: var(--color-orange);
}

.hero-subtitle {
    color: var(--color-grey-light);
    font-size: 1.25rem;
    margin-bottom: 2.5rem;
    max-width: 600px;
}

.hero-cta {
    display: flex;
    gap: 1rem;
}

/* Expertise Cards */
.cards {
    grid-template-columns: repeat(3, 1fr);
}

.card {
    background: var(--color-white);
    padding: 3rem 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-grey-border);
    transition: var(--transition);
    text-align: center;
}

.card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    border-color: var(--color-orange);
}

.card-icon {
    font-size: 3rem;
    color: var(--color-orange);
    margin-bottom: 1.5rem;
}

.card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

/* Ongoing Projects */
.project-showcase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    background: var(--color-white);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.project-details {
    padding: 4rem;
}

.badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: rgba(242, 106, 46, 0.1);
    color: var(--color-orange);
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
}

.project-details h3 {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.project-details p {
    margin-bottom: 2rem;
}

.project-tags {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.project-tags li {
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
    background: var(--color-grey-light);
    border-radius: 4px;
    color: var(--color-grey-dark);
    font-weight: 500;
}

.ongoing-img {
    height: 100%;
    min-height: 400px;
    background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('https://images.unsplash.com/photo-1503387762-592deb58ef4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80') center/cover;
    position: relative;
}

.status-overlay {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    background: rgba(255, 255, 255, 0.9);
    padding: 1rem 1.5rem;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--color-orange);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
}

/* Finished Gallery */
.gallery {
    grid-template-columns: repeat(3, 1fr);
}

.gallery-item {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/5;
    cursor: pointer;
}

.gallery-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.5s ease;
}

.placeholder-1 {
    background-image: url('https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80');
}

.placeholder-2 {
    background-image: url('https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80');
}

.placeholder-3 {
    background-image: url('https://images.unsplash.com/photo-1600607688969-a5bfcd64bd28?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80');
}

.gallery-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem;
    background: linear-gradient(transparent, rgba(26, 26, 26, 0.9));
    color: var(--color-white);
    transform: translateY(20px);
    opacity: 0;
    transition: var(--transition);
}

.gallery-item:hover .gallery-img {
    transform: scale(1.05);
}

.gallery-item:hover .gallery-content {
    transform: translateY(0);
    opacity: 1;
}

.gallery-content h4 {
    color: var(--color-white);
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
}

.gallery-content p {
    color: var(--color-orange);
    font-size: 0.875rem;
    font-weight: 600;
}

/* Footer */
.footer {
    background: var(--color-grey-dark);
    color: var(--color-white);
    padding: 5rem 0 2rem;
}

.footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 3rem;
    margin-bottom: 4rem;
}

.footer-brand .logo {
    margin-bottom: 1.5rem;
}

.footer-brand p {
    color: #9ca3af;
    margin-bottom: 2rem;
    max-width: 320px;
}

.footer-block h4 {
    color: var(--color-white);
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
}

.footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
}

.footer-nav a {
    color: #9ca3af;
    transition: var(--transition);
    display: inline-block;
}

.footer-nav a:hover {
    color: var(--color-orange);
    transform: translateX(5px);
}

.footer-contact p {
    color: #9ca3af;
    margin-bottom: 0.875rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
}

.footer-contact i {
    color: var(--color-orange);
    font-size: 1.25rem;
    margin-top: 0.2rem;
}

.socials {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.socials a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    transition: var(--transition);
    color: var(--color-white);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.socials a:hover {
    background: var(--color-orange);
    border-color: var(--color-orange);
    transform: translateY(-3px);
}

.footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: #9ca3af;
    font-size: 0.875rem;
}

@media (max-width: 900px) {
    .footer-content {
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }
}

/* Animations */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease;
}

.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

/* Responsive */
@media (max-width: 900px) {
    .nav-links {
        display: none;
    }

    .hero-title {
        font-size: 3rem;
    }

    .cards,
    .gallery {
        grid-template-columns: 1fr;
    }

    .project-showcase {
        grid-template-columns: 1fr;
    }

    .ongoing-img {
        min-height: 300px;
    }

    .footer-content {
        flex-direction: column;
        gap: 2rem;
    }
}
